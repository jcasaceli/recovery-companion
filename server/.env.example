# Copy to .env and fill in. NEVER commit the real .env.
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
# PORT=8787
# ASSISTANT_MODEL=claude-opus-4-8   # or claude-sonnet-4-6 for lower cost/latency

# ── Stripe (test mode first) ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PLATFORM_PRICE_ID=price_...      # your $60/mo recurring price
PUBLIC_RETURN_URL=https://example.com/return

# Supabase service role (server-only — NEVER ship in the app). Lets the server
# read/write each operator's Stripe account. Project Settings → API → service_role.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
