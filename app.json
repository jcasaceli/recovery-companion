{
  "expo": {
    "name": "Sober Living Companion",
    "slug": "recovery-companion",
    "version": "1.1.5",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.soberlivingcompanion.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.soberlivingcompanion.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Sober Living Companion uses your location only when you tap \u201cI\u2019m at a meeting\u201d to record where you checked in."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Sober Living Companion needs photo access so you can import a schedule from a picture.",
          "cameraPermission": "Sober Living Companion needs camera access so you can add a photo to a post or schedule."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Sober Living Companion needs calendar access to add your meetings and appointments."
        }
      ],
      "expo-notifications",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "a7e5eda1-360b-4d34-88c7-568f49822a7e"
      }
    },
    "owner": "jcasaceli"
  }
}