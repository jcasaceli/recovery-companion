# Copy to .env. Expo exposes EXPO_PUBLIC_* vars to the app at build time.
# Restart `expo start` after changing these.

# Backend proxy for the Claude assistant. Use your Mac's LAN IP, NOT localhost
# (a phone can't resolve the Mac's localhost). Leave unset to use the offline mock.
# EXPO_PUBLIC_BACKEND_URL=http://192.168.1.50:8787

# Supabase (optional — only when migrating off the local prototype store).
# EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...
